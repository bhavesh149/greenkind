# Copy to .env (see ../../docs/ENV.md for where each value comes from).

NODE_ENV=development
# Local dev: web runs on 3001 (see apps/web), API on 3000 — do not use the same port for both.
PORT=3000
# Listen address. If the port is "stuck", see docs/ENV.md (Troubleshooting).
API_HOST=0.0.0.0
# Local: `createdb greenkind` as your macOS user, then use that user in the URL (no password is ok for `user@host`).
DATABASE_URL=postgresql://user@localhost:5432/greenkind
# Must match the browser origin of the Next app (default local: http://localhost:3001)
FRONTEND_ORIGIN=http://localhost:3001

# Generate: openssl rand -base64 48 (min 32 chars). Use two different values.
JWT_ACCESS_SECRET=change-me-access-min-32-chars-required-here
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-required-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

REDIS_URL=redis://localhost:6379

# Set in test/CI to skip Bull when Redis is unavailable.
# SKIP_REDIS=1

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# price_... from Dashboard or: pnpm run stripe:seed-prices (INR by default; STRIPE_DEV_CURRENCY=usd for USD)
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
# One-off donation Checkout (price_data); e.g. inr, usd — must match Stripe account
STRIPE_DONATION_CURRENCY=inr

# Prize pool estimate: pool = active_subscribers * PRIZE_ESTIMATED_MRR_CENTS * PRIZE_POOL_REVPCT
# Tier split: 40% / 35% / 25% to 5- / 4- / 3-number matches. Unclaimed 5-match pool rolls over.
PRIZE_POOL_REVPCT=0.2
PRIZE_ESTIMATED_MRR_CENTS=1500

# Resend (https://resend.com) — welcome, billing, draw/winner, digest. Leave empty to skip sends locally.
# RESEND_API_KEY=re_...
# RESEND_FROM=GreenKind <onboarding@resend.dev>
# DISABLE_EMAIL_DIGEST=1
