// GreenKind — Prisma schema (see PRD_Cursor_Brief.md)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  SUBSCRIBER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  TRIAL
}

enum DrawMode {
  RANDOM
  ALGORITHMIC
}

enum DrawStatus {
  DRAFT
  SIMULATED
  PUBLISHED
  ARCHIVED
}

enum WinnerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

// ---------------------------------------------------------------------------
// User & auth
// ---------------------------------------------------------------------------

model User {
  id                    String   @id @default(uuid()) @db.Uuid
  email                 String   @unique
  passwordHash          String
  name                  String
  phone                 String?
  role                  UserRole @default(SUBSCRIBER)
  status                UserStatus @default(ACTIVE)
  selectedCharityId   String? @map("selected_charity_id") @db.Uuid
  charityContribution Int   @default(10) @map("charity_contribution") // percent, min 10 in app
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  selectedCharity Charity? @relation("UserSelectedCharity", fields: [selectedCharityId], references: [id], onDelete: SetNull)
  refreshTokens   RefreshToken[]
  subscription     Subscription?
  scores           Score[]
  donations        Donation[]
  winners          Winner[]
  notifications    Notification[]
  auditLogsAsActor AuditLog[]        @relation("AuditActor")
  createdCharities Charity[]         @relation("CharityCreatedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  provider             String             @default("stripe")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  lastPaymentAt        DateTime?          @map("last_payment_at")
  nextBillingAt        DateTime?          @map("next_billing_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model StripeEvent {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @unique @map("event_id")
  type       String
  receivedAt DateTime @default(now()) @map("received_at")
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([type])
  @@map("stripe_events")
}

// ---------------------------------------------------------------------------
// Scores
// ---------------------------------------------------------------------------

model Score {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  scoreDate  DateTime @map("score_date") @db.Date
  scoreValue Int      @map("score_value") // 1–45 Stableford, validate in app
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scoreDate])
  @@index([userId, scoreDate(sort: Desc)])
  @@map("scores")
}

// ---------------------------------------------------------------------------
// Charities
// ---------------------------------------------------------------------------

model Charity {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String
  category    String
  images      Json     @default("[]")
  events      Json     @default("[]")
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy     User?      @relation("CharityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  usersSelected User[]     @relation("UserSelectedCharity")
  donations     Donation[]

  @@index([slug])
  @@index([active, featured])
  @@map("charities")
}

model Donation {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  charityId             String   @map("charity_id") @db.Uuid
  amountCents           Int      @map("amount_cents")
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  createdAt             DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity Charity @relation(fields: [charityId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([charityId])
  @@map("donations")
}

// ---------------------------------------------------------------------------
// Draws & prize pool
// ---------------------------------------------------------------------------

model Draw {
  id                    String     @id @default(uuid()) @db.Uuid
  month                 DateTime   @db.Date
  mode                  DrawMode
  status                DrawStatus @default(DRAFT)
  generatedNumbers      Int[]      @map("generated_numbers")
  seed                  String? // for reproducibility / audit
  resultSummary         Json?      @map("result_summary")
  jackpotRolledOverFromId String?  @map("jackpot_rolled_over_from_id") @db.Uuid
  publishedAt          DateTime?  @map("published_at")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  jackpotRolledOverFrom Draw?   @relation("DrawJackpotRollover", fields: [jackpotRolledOverFromId], references: [id], onDelete: SetNull)
  drawsRollingHere      Draw[]  @relation("DrawJackpotRollover")
  winners                Winner[]

  @@unique([month])
  @@index([status])
  @@map("draws")
}

model PrizePoolLedger {
  id                 String   @id @default(uuid()) @db.Uuid
  month              DateTime @unique @db.Date
  activeSubscribers  Int      @map("active_subscribers")
  totalRevenueCents  Int      @map("total_revenue_cents")
  poolCents          Int      @map("pool_cents")
  tier5Cents         Int      @map("tier5_cents")
  tier4Cents         Int      @map("tier4_cents")
  tier3Cents         Int      @map("tier3_cents")
  rolloverInCents    Int      @default(0) @map("rollover_in_cents")
  rolloverOutCents   Int      @default(0) @map("rollover_out_cents")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([month])
  @@map("prize_pool_ledgers")
}

model Winner {
  id                 String                    @id @default(uuid()) @db.Uuid
  drawId             String                    @map("draw_id") @db.Uuid
  userId             String                    @map("user_id") @db.Uuid
  tier               Int
  matchCount         Int                      @map("match_count")
  payoutAmountCents  Int                      @map("payout_amount_cents")
  verificationStatus WinnerVerificationStatus  @map("verification_status")
  payoutStatus       PayoutStatus              @map("payout_status")
  proofImageKey      String?                  @map("proof_image_key")
  adminNotes         String?                  @map("admin_notes")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  draw Draw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([drawId, userId, tier])
  @@index([drawId])
  @@index([userId])
  @@index([verificationStatus])
  @@map("winners")
}

// ---------------------------------------------------------------------------
// Notifications & audit
// ---------------------------------------------------------------------------

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String
  title     String
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorUserId String? @map("actor_user_id") @db.Uuid
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  diff       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entity, createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}
