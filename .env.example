# Reference only — use per-app files:
#   apps/api/.env
#   apps/web/.env.local
#
# Full step-by-step: docs/ENV.md

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/greenkind
REDIS_URL=redis://localhost:6379
# API uses FRONTEND_ORIGIN; local Next dev defaults to :3001 (see docs/ENV.md)
FRONTEND_ORIGIN=http://localhost:3001
JWT_ACCESS_SECRET=min-32-chars-use-openssl-rand
JWT_REFRESH_SECRET=min-32-chars-different-from-access
